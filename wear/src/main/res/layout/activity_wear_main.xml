<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="16dp"
    android:background="@color/background_dark">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/wear_app_name"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:textColor="@color/text_light"
        android:layout_marginBottom="16dp" />

    <!-- Heart Rate Display -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_background"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_heart_rate"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="❤️ -- bpm"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/error_color" />
    </FrameLayout>

    <!-- Steps Display -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginBottom="12dp"
        android:background="@drawable/rounded_background"
        android:padding="8dp">

        <TextView
            android:id="@+id/tv_steps"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="👟 -- steps"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:textColor="@color/secondary_color" />
    </FrameLayout>

    <!-- Navigation Buttons -->
    <Button
        android:id="@+id/btn_health_monitor"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="@string/wear_health_monitor"
        android:layout_marginBottom="8dp"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_mood_tracking"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="@string/wear_mood_tracking"
        android:layout_marginBottom="8dp"
        android:textSize="14sp" />

    <Button
        android:id="@+id/btn_settings"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="@string/wear_settings"
        android:textSize="14sp" />

</LinearLayout>
